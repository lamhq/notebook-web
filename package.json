{
  "name": "notebook-web",
  "version": "3.1.0",
  "description": "Web UI for Notebook app",
  "author": "lamhq",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "start": "webpack serve --config webpack.dev.js",
    "build": "webpack --env production --config webpack.prod.js",
    "preversion": "git-branch-is -r \"^(feature|fix|hotfix)/NB-\\d+/[a-z\\-\\d\\.]+$\" && echo Preversion checks passed. Your branch name is correct format.",
    "test": "jest --coverage --errorOnDeprecated",
    "test:watch": "jest --watch",
    "lint": "eslint '*/**/*.{js,ts,tsx}' --quiet",
    "storybook": "start-storybook -p 6006",
    "build-storybook": "build-storybook",
    "release": "standard-version --no-verify && git push --no-verify && git push --tags --no-verify"
  },
  "husky": {
    "hooks": {
      "pre-commit": "yarn preversion && lint-staged",
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@date-io/date-fns": "^2.13.1",
    "@emotion/react": "^11.7.0",
    "@emotion/styled": "^11.6.0",
    "@hookform/resolvers": "^2.6.0",
    "@mui/icons-material": "^5.2.0",
    "@mui/lab": "^5.0.0-alpha.75",
    "@mui/material": "^5.2.1",
    "axios": "^0.21.1",
    "date-fns": "^2.28.0",
    "notistack": "^1.0.9",
    "numeral": "^2.0.6",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-error-boundary": "^3.1.3",
    "react-google-login": "^5.2.2",
    "react-hook-form": "^7.9.0",
    "react-router-dom": "^5.2.0",
    "recoil": "^0.3.1",
    "yup": "^0.32.9"
  },
  "devDependencies": {
    "@babel/core": "^7.14.6",
    "@commitlint/cli": "^11.0.0",
    "@commitlint/config-conventional": "^11.0.0",
    "@storybook/addon-actions": "^6.3.1",
    "@storybook/addon-essentials": "^6.3.1",
    "@storybook/addon-links": "^6.3.1",
    "@storybook/react": "^6.3.1",
    "@testing-library/jest-dom": "^5.11.1",
    "@testing-library/react": "^10.4.7",
    "@testing-library/react-hooks": "^3.4.1",
    "@types/jest": "^26.0.7",
    "@types/mini-css-extract-plugin": "^0.9.1",
    "@types/numeral": "^2.0.1",
    "@types/react": "^16.9.10",
    "@types/react-dom": "^16.9.10",
    "@types/react-router-dom": "^5.1.7",
    "@types/react-test-renderer": "^17.0.1",
    "@typescript-eslint/eslint-plugin": "^4.28.1",
    "@typescript-eslint/parser": "^4.28.1",
    "babel-loader": "^8.2.2",
    "css-loader": "^3.5.3",
    "css-minimizer-webpack-plugin": "^3.0.2",
    "eslint": "^6.0.0",
    "eslint-config-airbnb": "18.2.0",
    "eslint-config-prettier": "^6.11.0",
    "eslint-plugin-import": "^2.21.2",
    "eslint-plugin-jest": "^23.18.0",
    "eslint-plugin-jsx-a11y": "^6.3.0",
    "eslint-plugin-prettier": "^3.1.3",
    "eslint-plugin-react": "^7.20.0",
    "eslint-plugin-react-hooks": "^4.2.0",
    "fork-ts-checker-notifier-webpack-plugin": "^4.0.0",
    "fork-ts-checker-webpack-plugin": "^6.2.12",
    "git-branch-is": "^4.0.0",
    "html-webpack-plugin": "^5.3.2",
    "husky": "^4.3.7",
    "jest": "^26.1.0",
    "lint-staged": "^10.2.11",
    "mini-css-extract-plugin": "^1.6.2",
    "prettier": "^2.0.5",
    "react-test-renderer": "^17.0.2",
    "source-map-loader": "^1.0.1",
    "standard-version": "^9.3.2",
    "style-loader": "^1.2.1",
    "ts-jest": "^26.1.3",
    "ts-loader": "^9.2.3",
    "typescript": "^4.3.4",
    "webpack": "^5.41.0",
    "webpack-cli": "^4.7.2",
    "webpack-dev-server": "^3.11.2",
    "webpack-merge": "^5.8.0",
    "webpack-pwa-manifest": "^4.3.0"
  }
}
